-- Build a Discord embed with the script's blue accent. `fields` is
-- a list of {name, value, inline=true} tuples. inline defaults to
-- true unless explicitly set to false.
local function buildEmbed(title, color, fields)
    local f = {}
    for _, fld in ipairs(fields or {}) do
        table.insert(f, {
            name   = tostring(fld[1]),
            value  = tostring(fld[2]),
            inline = fld[3] ~= false,
        })
    end
    return {
        embeds = {{
            title  = title,
            color  = color,
            fields = f,
            footer = { text = "Rox's Menu | AOT:R" },
        }},
    }
end

-- Zero-width space (U+200B). Used as the name/value of an inline
-- "spacer" field — drops into the current row as a blank 3rd column
-- to force the next inline field onto a fresh row. Inline (not
-- non-inline) because a non-inline ZWSP field renders as TWO blank
-- lines (name + value), giving an awkward double gap; inline lets
-- it ride along the current row and the gap to the next row stays
-- at Discord's natural single-row spacing.
local ZWSP = "\226\128\139"
local SPACER = { ZWSP, ZWSP, true }

-- Appended to inline-field values to add one line of vertical
-- padding below them. Discord aligns inline fields by their top
-- edge and the row's bottom is at the tallest field's bottom — so
-- if every inline value ends with a newline + ZWSP, every row is
-- 2 value-lines tall and the next row starts a clean line below.
-- Cleanest way to get a consistent 1-line gap between every row
-- without inserting extra full-width spacer fields.
local PAD = "\n" .. ZWSP

-- Convenience colors (matches the script's own palette).
local EMBED_OK     = 0x5F91E6   -- accent blue (default mission completed)
local EMBED_WARN   = 0xFFC83C   -- amber (stuck mission)
local EMBED_BAD    = 0xFF6464   -- red (refill failed / unloaded)
local EMBED_GOOD   = 0x50DC8C   -- green (script loaded)

local function sendMissionCompleted(runKills, expGain, goldGain, timeTaken)
    sendWebhookRaw(buildEmbed("🎯 Mission Completed!", EMBED_OK, {
        -- PAD lives ONLY on the last cell of each row (Level, Time
        -- Taken, EXP Gained). That single trailing newline pushes
        -- the row's height up by one line so the next row starts
        -- with a clean visible gap. Same number of cells per row,
        -- but only one of them carries the padding — keeps the
        -- left-side cells visually clean.
        -- Row 1: identity / progression
        { "Player",        getPlayerName(),                          true },
        { "Killstreak",    tostring(getKillstreak()),                true },
        { "Level",         tostring(getLevel())             .. PAD,  true },
        -- Row 2: this mission's outcome
        { "Titans Killed", tostring(runKills or 0),                  true },
        { "Time Taken",    fmtMMSS(timeTaken or 0)          .. PAD,  true },
        -- Forced row break — without this, Discord packs Gold
        -- Gained onto row 2 (3 inline max per row) and EXP Gained
        -- ends up alone on row 3.
        SPACER,
        -- Row 3: this mission's gains
        { "Gold Gained",   "+" .. commaFmt(goldGain or 0),           true },
        { "EXP Gained",    ("+" .. commaFmt(expGain  or 0)) .. PAD,  true },
        -- Row 4: session-wide totals (full-width)
        { "Session Overall",
          string.format("EXP: %s  •  Gold: %s  •  Kills: %s\nRetries: %s  •  Uptime: %s",
              commaFmt(LifetimeStats.exp),
              commaFmt(LifetimeStats.gold),
              commaFmt(LifetimeStats.titansKilled),
              commaFmt(LifetimeStats.retries),
              fmtHumanDuration(LifetimeStats.uptime)),
          false },
    }))
end

