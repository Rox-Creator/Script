local function writePartSize(part, sizeVec)
    pcall(function() part.Size = sizeVec end)
    local okAddr, addr = pcall(function() return part.Address end)
    if not (okAddr and addr) then return end
    local okPrim, prim = pcall(memory_read, "uintptr_t", addr + Offsets.Primitive)
    if not (okPrim and prim and prim ~= 0) then return end
    pcall(memory_write, "float", prim + Offsets.PartSize + 0, sizeVec.X)
    pcall(memory_write, "float", prim + Offsets.PartSize + 4, sizeVec.Y)
    pcall(memory_write, "float", prim + Offsets.PartSize + 8, sizeVec.Z)
end

local function getNape(titan)
    local hitboxes = titan:FindFirstChild("Hitboxes")
    if not hitboxes then return nil end
    local hit = hitboxes:FindFirstChild("Hit")
    if not hit then return nil end
    return hit:FindFirstChild("Nape")
end

local function findHumanoid(titan)
    local h = titan:FindFirstChildOfClass("Humanoid")
    if h then return h end
    for _, child in ipairs(titan:GetChildren()) do
        local hh = child:FindFirstChildOfClass("Humanoid")
        if hh then return hh end
    end
    return nil
end

local function expandTitans()
    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then return end
    local sizeVec = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
    for _, titan in ipairs(titansFolder:GetChildren()) do
        local nape = getNape(titan)
        if nape then
            local okAddr, addr = pcall(function() return nape.Address end)
            if okAddr and addr and not OriginalSizes[addr] then
                local okSz, sz = pcall(function() return nape.Size end)
                if okSz and sz then OriginalSizes[addr] = sz end
            end
            writePartSize(nape, sizeVec)
        end
    end
end

local function restoreTitans()
    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then return end
    for _, titan in ipairs(titansFolder:GetChildren()) do
        local nape = getNape(titan)
        if nape then
            local okAddr, addr = pcall(function() return nape.Address end)
            if okAddr and addr and OriginalSizes[addr] then
                writePartSize(nape, OriginalSizes[addr])
            end
        end
    end
    OriginalSizes = {}
end

local function restoreAutoKillTitans()
    local titansFolder = Workspace:FindFirstChild("Titans")
    if titansFolder then
        for _, titan in ipairs(titansFolder:GetChildren()) do
            local nape = getNape(titan)
            if nape then
                local okAddr, addr = pcall(function() return nape.Address end)
                if okAddr and addr and AutoKillOriginalSizes[addr] then
                    writePartSize(nape, AutoKillOriginalSizes[addr])
                end
            end
        end
    end
    AutoKillOriginalSizes = {}
end

local function getHRP()
