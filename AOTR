-- AOT:R stores per-player stats (Streak, Level, etc.) as attributes
-- on the Player instance — i.e. game.Players.zWaleed = LocalPlayer.
-- The singular GetAttribute(name) call works on Player objects
-- (unlike on workspace Models, where Matcha's GetAttributes returns
-- only an array of names and GetAttribute returns nil).
local function getPlayerAttr(name)
    local ok, v = pcall(function() return LocalPlayer:GetAttribute(name) end)
    if ok then
        local n = tonumber(v)
        if n then return n end
