-- Auto Kill — self-contained farm using the drop+velocity pattern.
--   - Auto-engages a smaller (AutoKillHitboxSize) nape expansion so
--     the user doesn't need Hitbox Expander on separately.
--   - Each cycle TPs the player to (nape + AutoKillDropHeight) but
--     does NOT zero AssemblyLinearVelocity, so the downward velocity
--     from the previous drop carries over and the player slams
--     through the nape at increasing speed.
--   - Floor check exits the dwell early once the player crosses
--     (nape + AutoKillFloorBuffer), so they never reach nape level
--     (which would trigger nape-grab).
--   - Every AutoKillAnchorEvery cycles, the assembly's linear
--     velocity is INSTANTLY zeroed (no hold) so the player can't
--     run away with the speed buildup. Lower this knob if you're
--     overshooting; raise it for harder slams.
--   - Grab bailout: if the target titan has any "*grab*" attribute
--     set true (Left_nape_grab / Right_air_grab / etc.), the loop
--     TPs the player up high, zeroes velocity, and freezes for 0.5s.
task.spawn(function()
    local prevActive = false
    local lastAttack = 0
    local activeTitan, activeNape = nil, nil
    local cycleCount = 0

    local function applyHitbox()
        local titansFolder = Workspace:FindFirstChild("Titans")
        if not titansFolder then return end
        local sizeVec = Vector3.new(AutoKillHitboxSize, AutoKillHitboxSize, AutoKillHitboxSize)
        for _, titan in ipairs(titansFolder:GetChildren()) do
            local nape = getNape(titan)
            if nape then
                local okAddr, addr = pcall(function() return nape.Address end)
                if okAddr and addr and not AutoKillOriginalSizes[addr] then
                    local okSz, sz = pcall(function() return nape.Size end)
                    if okSz and sz then AutoKillOriginalSizes[addr] = sz end
                end
                writePartSize(nape, sizeVec)
            end
        end
    end

    while GUI.Running do
        if Features.AutoKill or Features.ErenRaid then
            prevActive = true

            applyHitbox()

            -- Target picker depends on mode. ErenRaid prioritises
            -- the titan closest to the rock (so they never reach it)
            -- and re-evaluates EVERY cycle — if a new titan spawns
            -- closer to the rock, we hot-swap to it immediately.
            -- Plain AutoKill takes whichever titan is nearest the
            -- player and only swaps when the current one dies.
            -- ErenRaid wins if both are on.
            if Features.ErenRaid then
                local newTitan, newNape = getNearestLiveTitanToRock()
                if newTitan ~= activeTitan then
                    activeTitan, activeNape = newTitan, newNape
                    cycleCount = 0
                end
            elseif not (activeTitan and findHumanoid(activeTitan)) then
                activeTitan, activeNape = getNearestLiveTitan()
                cycleCount = 0
            end

            if activeTitan and activeNape then
                local hrp = getHRP()
                local okN, npos = pcall(function() return activeNape.Position end)
                if hrp and okN and npos then
                    -- Grab bailout. If any "*grab*" attribute on the
                    -- target titan is set, TP up high, zero velocity,
                    -- and freeze 0.5s so we don't get held.
                    if isTitanGrabbing(activeTitan) then
                        pcall(function()
                            hrp.CFrame = CFrame.new(npos.X, npos.Y + AutoKillDropHeight + 60, npos.Z)
                        end)
                        pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
                        pcall(function() hrp.Velocity = Vector3.zero end)
                        task.wait(0.5)
                        cycleCount = 0
                    else
                        -- Standard cycle: TP up, leave velocity alone.
                        pcall(function()
                            hrp.CFrame = CFrame.new(npos.X, npos.Y + AutoKillDropHeight, npos.Z)
                        end)

                        cycleCount = cycleCount + 1

                        -- Periodic INSTANT velocity reset. Every Nth
                        -- cycle, zero the assembly's linear velocity
                        -- right after the TP-up — no hold loop. The
                        -- next cycle starts from a clean 0, so the
                        -- player only ever has at most N cycles' worth
                        -- of accumulated speed.
                        if cycleCount >= AutoKillAnchorEvery then
                            cycleCount = 0
                            pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
                            pcall(function() hrp.Velocity = Vector3.zero end)
                        end

                        if tick() - lastAttack >= KillCooldown then
                            performAttack()
                            lastAttack = tick()
                        end

                        -- Dwell with floor-check.
                        local floorY  = npos.Y + AutoKillFloorBuffer
                        local dwellEnd = tick() + AutoKillDropDwell
                        while tick() < dwellEnd do
                            local h2 = getHRP()
                            if not h2 then break end
                            local okP, p = pcall(function() return h2.Position end)
                            if okP and p and p.Y <= floorY then break end
                            task.wait(0.015)
                        end
                    end
                end
            else
                task.wait(0.3)
            end
        else
            if prevActive then
                restoreAutoKillTitans()
                activeTitan, activeNape = nil, nil
                cycleCount = 0
                prevActive = false
            end
            task.wait(0.2)
        end
    end
end)

