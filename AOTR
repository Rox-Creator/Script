-- Auto-save just the AutoKill on/off flag. Reads the existing
-- config, patches the one field, writes back — so other unsaved
-- tweaks (slider, binds, other toggles) aren't accidentally
-- committed when AutoKill flips. Why this exists: the user can't
-- click "Save Config" while AutoKill is on, because the loop is
-- pressing the mouse for them.
local function saveAutoKillState()
    if type(writefile) ~= "function" then return end
    task.spawn(function()
        local data = {}
        if type(readfile) == "function" and type(isfile) == "function"
           and isfile(CONFIG_PATH) then
            local ok, raw = pcall(readfile, CONFIG_PATH)
            if ok and type(raw) == "string" then
                local okJ, decoded = pcall(function() return HttpService:JSONDecode(raw) end)
                if okJ and type(decoded) == "table" then data = decoded end
            end
        end
        data.features = data.features or {}
        data.features.AutoKill = Features.AutoKill
        pcall(function()
            if type(makefolder) == "function" and type(isfolder) == "function"
               and not isfolder(CONFIG_DIR) then
                makefolder(CONFIG_DIR)
            end
            writefile(CONFIG_PATH, HttpService:JSONEncode(data))
        end)
    end)
end

local function loadConfig()
    if type(readfile) ~= "function" or type(isfile) ~= "function" then return end
    if not isfile(CONFIG_PATH) then return end
    local ok, raw = pcall(readfile, CONFIG_PATH)
    if not (ok and raw) then return end
    local okJ, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not (okJ and type(data) == "table") then return end

    if type(data.binds) == "table" then
        if type(data.binds.toggle)   == "number" then GUI.ToggleKey = data.binds.toggle   end
        if type(data.binds.hitbox)   == "number" then HitboxKey     = data.binds.hitbox   end
        if type(data.binds.autokill) == "number" then AutoKillKey   = data.binds.autokill end
    end
    if type(data.settings) == "table" then
        if type(data.settings.hitboxSize) == "number" then HitboxSize = data.settings.hitboxSize end
    end
    if type(data.features) == "table" then
        if type(data.features.HitboxExpander) == "boolean" then Features.HitboxExpander = data.features.HitboxExpander end
        if type(data.features.AutoKill)       == "boolean" then Features.AutoKill       = data.features.AutoKill       end
        if type(data.features.AutoQTE)        == "boolean" then Features.AutoQTE        = data.features.AutoQTE        end
        if type(data.features.AutoRetry)      == "boolean" then Features.AutoRetry      = data.features.AutoRetry      end
        if type(data.features.ErenRaid)       == "boolean" then Features.ErenRaid       = data.features.ErenRaid       end
        if type(data.features.AutoRefill)     == "boolean" then Features.AutoRefill     = data.features.AutoRefill     end
        if (Features.AutoKill or Features.ErenRaid) and not killUptime.start then
            killUptime.start = tick()
        end
    end
end

