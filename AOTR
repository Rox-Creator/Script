applyMinimizedState = function()
    if GUI.Minimized then
        for _, el in ipairs(GUI.Elements)        do pcall(function() el.Visible = false end) end
        for _, el in ipairs(GUI.NavElements)     do pcall(function() el.Visible = false end) end
        for _, el in ipairs(GUI.SubTabElements)  do pcall(function() el.Visible = false end) end
        ClearContent()
        buildMiniPanel()
    else
        clearMiniPanel()
        if GUI.Visible then
            for _, el in ipairs(GUI.Elements)    do pcall(function() el.Visible = true end) end
            for _, el in ipairs(GUI.NavElements) do pcall(function() el.Visible = true end) end
            CreateContent()
        end
    end
end

setHitboxOn = function(on)
    if Features.HitboxExpander == on then return end
    Features.HitboxExpander = on
    if not on then restoreTitans() end
    if GUI.Visible then CreateContent() end
end

setAutoKillOn = function(on)
    if Features.AutoKill == on then return end
    Features.AutoKill = on
    syncKillUptime()
    if on then lastKillAt = tick() end   -- arm stuck-mission watchdog
    saveAutoKillState()                  -- persist on/off across reloads
    if GUI.Visible then CreateContent() end
end

