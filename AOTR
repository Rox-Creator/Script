local function loadLifetimeStats()
    if type(readfile) ~= "function" or type(isfile) ~= "function" then return end
    if not isfile(STATS_PATH) then return end
    local ok, raw = pcall(readfile, STATS_PATH)
    if not (ok and raw) then return end
    local okJ, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not (okJ and type(data) == "table") then return end
    if type(data.titansKilled) == "number" then LifetimeStats.titansKilled = data.titansKilled end
    if type(data.exp)          == "number" then LifetimeStats.exp          = data.exp          end
    if type(data.gold)         == "number" then LifetimeStats.gold         = data.gold         end
    if type(data.retries)      == "number" then LifetimeStats.retries      = data.retries      end
    if type(data.uptime)       == "number" then LifetimeStats.uptime       = data.uptime       end
end

local function saveLifetimeStats()
    if type(writefile) ~= "function" then return end
    LifetimeDirty = false
    task.spawn(function()
        pcall(function()
            if type(makefolder) == "function" and type(isfolder) == "function"
               and not isfolder(CONFIG_DIR) then
                makefolder(CONFIG_DIR)
            end
            writefile(STATS_PATH, HttpService:JSONEncode(LifetimeStats))
        end)
    end)
end

