-- Auto Retry — when "Mission Completed" comes up, drive Roblox's
-- built-in GUI navigation to focus and activate the RETRY button.
-- Matcha can't fire button signals or use absolute mouse coords
-- reliably (Roblox windowed mode breaks mousemoveabs), but Roblox's
-- own keyboard nav works:
--   \         toggles GUI navigation mode (focus appears on a button)
--   Right ×2  steps focus from default (Leave) → Modify → Retry
--   Enter     activates the focused button
-- We detect the Rewards screen by walking to its Buttons.Retry path
-- (CanvasGroup root has no AbsoluteSize) and confirming the button
-- has a non-zero AbsoluteSize.
local VK_BACKSLASH = 0xDC   -- "\" / VK_OEM_5
local VK_D         = 0x44   -- D key (replaces right-arrow for GUI nav step)
local VK_ENTER     = 0x0D

task.spawn(function()
    local lastFire           = 0
    local lastSawLiveTitan   = 0      -- tick() at which we last saw a Humanoid'd titan
    local firedThisSession   = false  -- prevents re-firing while rewards is still up

    -- The Rewards CanvasGroup is permanent in PlayerGui (just faded
    -- in/out via GroupTransparency, which Matcha can't read), so an
    -- existence check on Buttons.Retry is true 100% of the time.
    -- Instead we use a behavioral signal: the rewards screen only
    -- shows when the mission ends → just before that, there were
    -- live titans, and now there aren't. Track when we last saw one.
    local function retryButtonExists()
        local pg     = LocalPlayer:FindFirstChild("PlayerGui")
        local iface  = pg     and pg:FindFirstChild("Interface")
        local rew    = iface  and iface:FindFirstChild("Rewards")
        local mainA  = rew    and rew:FindFirstChild("Main")
        local info   = mainA  and mainA:FindFirstChild("Info")
        local mainB  = info   and info:FindFirstChild("Main")
        local btns   = mainB  and mainB:FindFirstChild("Buttons")
        local retry  = btns   and btns:FindFirstChild("Retry")
        return retry ~= nil
    end

    local function anyLiveTitan()
        local titans = Workspace:FindFirstChild("Titans")
        if not titans then return false end
        for _, t in ipairs(titans:GetChildren()) do
            if findHumanoid(t) then return true end
        end
        return false
    end

    local function tap(vk)
        pcall(keypress, vk)
        task.wait(0.08)
        pcall(keyrelease, vk)
    end

    while GUI.Running do
        do
            local hasTitan = anyLiveTitan()

            if hasTitan then
                lastSawLiveTitan = tick()
                firedThisSession = false   -- new mission active, arm us again
            end

            -- Two firing paths, OR'd together. The retry button must
            -- always exist + cooldown must be met + we haven't fired
            -- this session. Beyond that:
            --
            --   A. NORMAL: had live titans within the last 3-30s and
            --      now there are none → mission ended cleanly.
            --   B. STUCK MISSION: AutoKill is on, titan models still
            --      exist in workspace (so it's not a between-rounds
            --      idle), but no kill has happened in 3+ minutes —
            --      mission probably ended weirdly with titans still
            --      alive and we're frozen out. Force a retry.
            local sinceTitan = tick() - lastSawLiveTitan
            local cleanEnd = (not hasTitan)
                         and sinceTitan >= 3.0
                         and sinceTitan < 30
            local stuckMission = Features.AutoKill
                              and (tick() - lastKillAt) > 180
                              and getTitanCount() > 0
            if (cleanEnd or stuckMission)
               and (not firedThisSession)
               and (tick() - lastFire > 4.0)
               and retryButtonExists() then
                firedThisSession = true
                lastFire = tick()
                if stuckMission and not cleanEnd then
                    pcall(notify,
                        "Stuck mission detected — forcing retry",
                        "AOT:R", 3)
                    sendStuckMission()
                end

                -- Re-inject after the sub-place transition. AOT:R's
                -- retry teleports to a new sub-place, which spawns a
                -- fresh Lua VM and kills our coroutines. Matcha's
                -- autoexec only fires on the first game join, so it
                -- won't re-run on sub-place hops. queue_on_teleport
                -- queues code to run once the next teleport completes
                -- — we point it at the on-disk copy of this script so
                -- it reloads itself on the new map.
                --
                -- One-time setup the user has to do:
                --   1. Save AOTR.lua to c:\matcha\workspace\AOTR\AOTR.lua
                --   2. Put this in Matcha's auto-execute slot (for the
                --      initial game join):
                --        pcall(function()
                --            loadstring(readfile("AOTR/AOTR.lua"))()
                --        end)
                pcall(function()
                    if queue_on_teleport then
                        queue_on_teleport([[
                            pcall(function()
                                if isfile and isfile("AOTR/AOTR.lua") then
                                    loadstring(readfile("AOTR/AOTR.lua"))()
                                end
                            end)
                        ]])
                    end
                end)

                -- Capture rewards BEFORE we start the retry sequence,
                -- while the Rewards screen is still visible. EXP is
                -- always slot 1_1, Gold is always slot 1_2 in AOT:R.
                local expGain  = getRewardItemQuantity("1_1") or 0
                local goldGain = getRewardItemQuantity("1_2") or 0
                LifetimeStats.exp     = LifetimeStats.exp     + expGain
                LifetimeStats.gold    = LifetimeStats.gold    + goldGain
                LifetimeStats.retries = LifetimeStats.retries + 1
                LifetimeDirty = true

                -- Send the mission-completed embed only on the clean
                -- end path (cleanEnd). The stuck-mission embed has
                -- already been sent above and these run-stats won't
                -- be meaningful in that case. Read Time Taken from
                -- the rewards UI itself — the in-game timer is the
                -- truth, not anything we'd compute here.
                local timeTaken = getRewardTimeTaken() or 0
                if cleanEnd then
                    sendMissionCompleted(Stats.RunKills, expGain, goldGain, timeTaken)
                end
                Stats.RunKills = 0      -- arm for next mission either way

                -- Sequence: \ engages GUI nav (focus lands on Leave),
                -- two D presses step Leave → Modify → Retry, then
                -- Enter activates. 1.5s gap between every press so
                -- each input registers before the next.
                tap(VK_BACKSLASH)
                task.wait(0.3)
                tap(VK_D)
                task.wait(0.3)
                tap(VK_D)
                task.wait(0.3)
                tap(VK_ENTER)
            end
        end
        task.wait(0.5)
    end
end)

-- Lifetime stats: accumulate uptime in 5s ticks while a kill mode is
-- active, and flush to disk every 30s (or sooner if a counter event
-- has marked the stats dirty). Uses a separate cadence from the
-- counter increments so we batch disk writes.
task.spawn(function()
    local lastSaveAt = tick()
    while GUI.Running do
        task.wait(5)
        if Features.AutoKill or Features.ErenRaid then
            LifetimeStats.uptime = LifetimeStats.uptime + 5
            LifetimeDirty = true
        end
        if LifetimeDirty and tick() - lastSaveAt >= 30 then
            saveLifetimeStats()
            lastSaveAt = tick()
        end
    end
end)

-- Kill counter — watches titan alive→dead transitions
task.spawn(function()
    local lastTitanState = {}
    while GUI.Running do
        task.wait(0.5)
        if Features.AutoKill or Features.ErenRaid then
            local folder = Workspace:FindFirstChild("Titans")
            if folder then
                local seen = {}
                for _, titan in ipairs(folder:GetChildren()) do
                    local okA, addr = pcall(function() return titan.Address end)
                    if okA and addr then
                        seen[addr] = true
                        local alive = findHumanoid(titan) ~= nil
                        if lastTitanState[addr] == true and not alive then
                            Stats.TitansKilled = Stats.TitansKilled + 1
                            Stats.RunKills     = Stats.RunKills + 1
                            LifetimeStats.titansKilled = LifetimeStats.titansKilled + 1
                            LifetimeDirty = true
                            lastKillAt = tick()
                        end
                        lastTitanState[addr] = alive
                    end
                end
                for addr in pairs(lastTitanState) do
                    if not seen[addr] then lastTitanState[addr] = nil end
                end
            end
        end
    end
end)

