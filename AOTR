-- Returns nearest titan that still has a Humanoid, with both the
-- titan model and its nape. Returns nil, nil if none.
local function getNearestLiveTitan()
    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then return nil, nil end
    local hrp = getHRP()
    if not hrp then return nil, nil end
    local okPP, pPos = pcall(function() return hrp.Position end)
    if not (okPP and pPos) then return nil, nil end
    local bestTitan, bestNape, bestD2 = nil, nil, math.huge
    for _, titan in ipairs(titansFolder:GetChildren()) do
        if findHumanoid(titan) then
            local nape = getNape(titan)
            if nape then
                local okN, npos = pcall(function() return nape.Position end)
                if okN and npos then
                    local dx = pPos.X - npos.X
                    local dy = pPos.Y - npos.Y
                    local dz = pPos.Z - npos.Z
                    local d2 = dx*dx + dy*dy + dz*dz
                    if d2 < bestD2 then
                        bestD2 = d2; bestTitan = titan; bestNape = nape
                    end
                end
            end
        end
    end
    return bestTitan, bestNape
end

-- Eren Raid: returns the live titan whose nape is closest to the
-- BigRock (not the player). Falls back to nearest-to-player if the
-- rock isn't reachable. Sorting only by distance to rock means the
-- loop will always cycle to whichever titan is the biggest threat.
local function getNearestLiveTitanToRock()
    local rockPos
    pcall(function()
        rockPos = Workspace.Unclimbable.Objective.Defend_Eren.BigRock.Position
    end)
    if not rockPos then return getNearestLiveTitan() end

    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then return nil, nil end
    local bestTitan, bestNape, bestD2 = nil, nil, math.huge
    for _, titan in ipairs(titansFolder:GetChildren()) do
        if findHumanoid(titan) then
            local nape = getNape(titan)
            if nape then
                local okN, npos = pcall(function() return nape.Position end)
                if okN and npos then
                    local dx = rockPos.X - npos.X
                    local dy = rockPos.Y - npos.Y
                    local dz = rockPos.Z - npos.Z
                    local d2 = dx*dx + dy*dy + dz*dz
                    if d2 < bestD2 then
                        bestD2 = d2; bestTitan = titan; bestNape = nape
                    end
                end
            end
        end
    end
    return bestTitan, bestNape
end

-- Detects whether the target titan currently has any "*grab*"
-- attribute set, e.g. Left_nape_grab / Right_nape_grab / Left_air_grab
-- / right_air_grab. AOT:R sets these mid-grab animation. The Auto Kill
-- loop bails (TPs high, freezes 0.5s) when any of these go true so
-- the player isn't held inside the titan's grab hitbox.
local function isTitanGrabbing(titan)
    if not titan then return false end
    local attrs
    pcall(function() attrs = titan:GetAttributes() end)
    if type(attrs) ~= "table" then return false end
    for k, v in pairs(attrs) do
        if v and string.lower(tostring(k)):find("grab") then
            return true
        end
    end
    return false
end

local function getOrCreateLine(idx)
    local ln = VisualizerLines[idx]
    if ln then return ln end
    ln = Drawing.new("Line")
    ln.Color = VIS_COLOR
    ln.Thickness = 1
    ln.Visible = false
    ln.ZIndex = 50
    VisualizerLines[idx] = ln
    return ln
end

-- Free every Drawing.Line in the pool. Hiding them isn't enough —
-- Matcha caps total Drawing instances and a hidden line still counts
-- against that budget, which is what eventually crashes us if the
-- user toggles the visualizer on/off across a long session.
local function hideAllVisualizerLines()
    for _, ln in ipairs(VisualizerLines) do
        pcall(function() ln:Remove() end)
    end
    VisualizerLines = {}
end

local function updateVisualizer()
    if not Features.Visualizer then hideAllVisualizerLines() return end
    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then hideAllVisualizerLines() return end
    local lineIdx = 0
    for _, titan in ipairs(titansFolder:GetChildren()) do
        local nape = findHumanoid(titan) and getNape(titan) or nil
        if nape then
            local okSz, sz  = pcall(function() return nape.Size end)
            local okCF, cf  = pcall(function() return nape.CFrame end)
            local okPos, ps = pcall(function() return nape.Position end)
            if okSz and sz and ((okCF and cf) or (okPos and ps)) then
                local hx, hy, hz = sz.X / 2, sz.Y / 2, sz.Z / 2
                local screenCorners = {}
                local anyOnScreen = false
                for i = 1, 8 do
                    local s = CornerSigns[i]
                    local world
                    if cf then
                        local okW, w = pcall(function()
                            return cf * Vector3.new(s.X * hx, s.Y * hy, s.Z * hz)
                        end)
                        if okW then world = w end
                    else
                        world = ps + Vector3.new(s.X * hx, s.Y * hy, s.Z * hz)
                    end
                    if world then
                        local s2d, onScreen = WorldToScreen(world)
                        if s2d then
                            screenCorners[i] = s2d
                            if onScreen then anyOnScreen = true end
                        end
                    end
                end
                if anyOnScreen then
                    for _, e in ipairs(BoxEdges) do
                        local p1 = screenCorners[e[1]]
                        local p2 = screenCorners[e[2]]
                        if p1 and p2 then
                            lineIdx = lineIdx + 1
                            local ln = getOrCreateLine(lineIdx)
                            pcall(function()
                                ln.From = p1; ln.To = p2; ln.Visible = true
                            end)
                        end
                    end
                end
            end
        end
    end
    for i = lineIdx + 1, #VisualizerLines do
        pcall(function() VisualizerLines[i].Visible = false end)
    end
end

