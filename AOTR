-- Format integers with comma thousands separators ("1234567" →
-- "1,234,567"). Declared up here so the webhook senders below can
-- use it; FormatUptime / the original commaFmt callsite further
-- down still works with this definition (single source of truth).
local function commaFmt(n)
    n = math.floor(tonumber(n) or 0)
    local s = tostring(n)
    while true do
        local replaced
        s, replaced = s:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
        if replaced == 0 then break end
    end
    return s
end

-- "01:49" style for the per-mission timer.
local function fmtMMSS(seconds)
    seconds = math.floor(tonumber(seconds) or 0)
    return string.format("%02d:%02d", math.floor(seconds / 60), seconds % 60)
end

-- "2m 0s" / "1h 23m" style for session uptime.
local function fmtHumanDuration(seconds)
    seconds = math.floor(tonumber(seconds) or 0)
    if seconds < 60 then return seconds .. "s" end
    local m = math.floor(seconds / 60)
    local s = seconds % 60
    if m < 60 then return string.format("%dm %ds", m, s) end
    local h = math.floor(m / 60)
    m = m % 60
    return string.format("%dh %dm", h, m)
end

-- ----- Discord webhook ---------------------------------------

-- Pulls the URL from the `Webhook_URL` global the user sets above
-- the loadstring call. Validates it looks like a real Discord
-- webhook URL — anything else is dropped.
local function loadWebhookUrl()
    if type(Webhook_URL) ~= "string" then return end
    local trimmed = Webhook_URL:gsub("^[%s]+", ""):gsub("[%s]+$", "")
    if trimmed:match("^https://discord%.com/api/webhooks/") or
       trimmed:match("^https://discordapp%.com/api/webhooks/") then
        WEBHOOK_URL = trimmed
    end
end

-- POSTs a JSON-encoded payload to the webhook. Matcha exposes
-- `game:HttpPost(url, body, contentType)` (and the lowercase
-- `httppost` alias). The executor-style `request` / `syn.request` /
-- `HttpService:PostAsync` calls are NOT available in Matcha — those
-- silently fail under pcall, which is why earlier versions of this
-- function appeared to no-op even when WEBHOOK_URL was set.
local function sendWebhookRaw(payload)
    if WEBHOOK_URL == "" then return end
    local body = HttpService:JSONEncode(payload)
    task.spawn(function()
        local fired = false
        local function try(fn)
            if fired then return end
            local ok, err = pcall(fn)
            if ok then fired = true
            else print("[AOT:R webhook] " .. tostring(err)) end
        end
        try(function() return game:HttpPost(WEBHOOK_URL, body, "application/json") end)
        try(function() return httppost(WEBHOOK_URL, body, "application/json") end)
    end)
end

