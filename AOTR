local NavDefs = {
    { name = "Main",     dot = Colors.AccentRed },
    { name = "Raid",     dot = Colors.TextMuted },
    { name = "Settings", dot = Colors.TextMuted },
}

local NavButtonHandles = {}

local function refreshNavButton(handles, selected)
    if not handles then return end
    if handles.dot then
        pcall(function()
            handles.dot.Color = selected and Colors.AccentRed or Colors.TextMuted
        end)
    end
    if handles.text then
        pcall(function()
            handles.text.Color = selected and Colors.TextPrimary or Colors.TextMuted
            handles.text.Font  = selected and Drawing.Fonts.SystemBold or Drawing.Fonts.System
        end)
    end
end

local function CreateMainTabs()
    local wx, wy = Config.WinX, Config.WinY
    local barY = wy + Config.HeaderH
    local barH = Config.TabStripH
    local nTabs = #NavDefs
    local tabW = Config.WinW / nTabs

    local stripBg = Drawing.new("Square")
    stripBg.Position = Vector2.new(wx, barY)
    stripBg.Size = Vector2.new(Config.WinW, barH)
    stripBg.Color = Colors.HeaderBg
    stripBg.Filled = true; stripBg.Visible = true; stripBg.ZIndex = 4
    table.insert(GUI.NavElements, stripBg)

    for i, def in ipairs(NavDefs) do
        local zoneX = wx + (i - 1) * tabW
        local zoneCenter = zoneX + tabW / 2
        local selected = (def.name == GUI.SelectedPage)

        local labelW = #def.name * 10
        local pairW  = 8 + 8 + labelW
        local pairStart = zoneCenter - pairW / 2

        local dot = Drawing.new("Circle")
        dot.Position = Vector2.new(pairStart + 5, barY + barH / 2 + 1)
        dot.Radius = 4; dot.Color = selected and Colors.AccentRed or Colors.TextMuted
        dot.Filled = true; dot.NumSides = 16
        dot.Visible = true; dot.ZIndex = 6
        table.insert(GUI.NavElements, dot)

        local txt = Drawing.new("Text")
        txt.Position = Vector2.new(pairStart + 16, barY + 10)
        txt.Text = def.name
        txt.Color = selected and Colors.TextPrimary or Colors.TextMuted
        txt.Size = 18
        txt.Font = selected and Drawing.Fonts.SystemBold or Drawing.Fonts.System
        txt.Center = false; txt.Outline = false
        txt.Visible = true; txt.ZIndex = 6
        table.insert(GUI.NavElements, txt)

        if selected then
            local underline = Drawing.new("Line")
            underline.From = Vector2.new(zoneCenter - 44, barY + barH - 3)
            underline.To   = Vector2.new(zoneCenter + 44, barY + barH - 3)
            underline.Color = Colors.AccentRed; underline.Thickness = 2
            underline.Visible = true; underline.ZIndex = 6
            table.insert(GUI.NavElements, underline)
            GUI.MainTabUnderline = underline
        end

        if i == 1 then
            local sep = Drawing.new("Line")
            sep.From = Vector2.new(wx, barY + barH)
            sep.To   = Vector2.new(wx + Config.WinW, barY + barH)
            sep.Color = Colors.Separator; sep.Thickness = 1
            sep.Visible = true; sep.ZIndex = 5
            table.insert(GUI.NavElements, sep)
        end

        NavButtonHandles[def.name] = { dot = dot, text = txt }

        local clickName = def.name
        table.insert(GUI.NavClickables, {
            x = zoneX, y = barY, w = tabW, h = barH,
            onClick = function()
                if GUI.SelectedPage == clickName then return end
                local oldName = GUI.SelectedPage
                GUI.SelectedPage = clickName
                if clickName == "Main" then GUI.SubTab = GUI.SubTab or "Automation" end
                for _, n in ipairs(NavDefs) do
                    refreshNavButton(NavButtonHandles[n.name], n.name == clickName)
                end
                local under = GUI.MainTabUnderline
                local function rebuild() CreateContent() end
                if under then
                    local fromIdx, toIdx = 1, 1
                    for j, d in ipairs(NavDefs) do
                        if d.name == oldName  then fromIdx = j end
                        if d.name == clickName then toIdx  = j end
                    end
                    local liveWx   = Config.WinX
                    local liveBarY = Config.WinY + Config.HeaderH
                    local fromCenter = liveWx + (fromIdx - 1) * tabW + tabW / 2
                    local toCenter   = liveWx + (toIdx  - 1) * tabW + tabW / 2
                    local lineY      = liveBarY + barH - 3
                    local token = newAnimToken()
                    task.spawn(function()
                        local steps = 10
                        for s = 1, steps do
                            if not isAnimCurrent(token) then return end
                            local t = s / steps
                            local et = 1 - (1 - t) ^ 3
                            local cx = fromCenter + (toCenter - fromCenter) * et
                            pcall(function()
                                under.From = Vector2.new(cx - 44, lineY)
                                under.To   = Vector2.new(cx + 44, lineY)
                            end)
                            task.wait(0.018)
                        end
                        rebuild()
                    end)
                else
                    rebuild()
                end
            end,
        })
    end
end

local SubTabDefs = { "Automation" }

local function CreateSubTabs()
    if GUI.SelectedPage ~= "Main" then return end
    local wx, wy = Config.WinX, Config.WinY
    local barY = wy + Config.HeaderH + Config.TabStripH
    local barH = Config.SubTabH
    local tabW = Config.WinW / #SubTabDefs

    for i, name in ipairs(SubTabDefs) do
        local zoneX = wx + (i - 1) * tabW
        local selected = (GUI.SubTab == name)

        if selected then
            local glow = Drawing.new("Square")
            glow.Position = Vector2.new(zoneX, barY); glow.Size = Vector2.new(tabW, barH)
            glow.Color = Colors.AccentRed; glow.Filled = true
            glow.Transparency = 0.12
            glow.Visible = true; glow.ZIndex = 4
            table.insert(GUI.SubTabElements, glow)
            GUI.SubTabGlow = glow
        end

        local txt = Drawing.new("Text")
        txt.Position = Vector2.new(zoneX + tabW / 2, barY + 14)
        txt.Text = name
        txt.Color = selected and Colors.TextPrimary or Colors.TextMuted
        txt.Size = 14
        txt.Font = selected and Drawing.Fonts.SystemBold or Drawing.Fonts.System
        txt.Center = true; txt.Outline = false
        txt.Visible = true; txt.ZIndex = 6
        table.insert(GUI.SubTabElements, txt)

        if selected then
            local underline = Drawing.new("Line")
            underline.From = Vector2.new(zoneX + 1, barY + barH - 2)
            underline.To = Vector2.new(zoneX + tabW - 1, barY + barH - 2)
            underline.Color = Colors.AccentRed; underline.Thickness = 2
            underline.Visible = true; underline.ZIndex = 6
            table.insert(GUI.SubTabElements, underline)
            GUI.SubTabUnderline = underline
        end

        if i == 1 then
            local sep = Drawing.new("Line")
            sep.From = Vector2.new(wx, barY + barH)
            sep.To = Vector2.new(wx + Config.WinW, barY + barH)
            sep.Color = Colors.Separator; sep.Thickness = 1
            sep.Visible = true; sep.ZIndex = 5
            table.insert(GUI.SubTabElements, sep)
        end

        local clickName = name
        table.insert(GUI.Clickables, {
            x = zoneX, y = barY, w = tabW, h = barH,
            onClick = function()
                if GUI.SubTab == clickName then return end
                local oldName = GUI.SubTab
                GUI.SubTab = clickName
                local under = GUI.SubTabUnderline
                local glow  = GUI.SubTabGlow
                local function rebuild() CreateContent() end
                if under then
                    local fromIdx, toIdx = 1, 1
                    for j, n in ipairs(SubTabDefs) do
                        if n == oldName   then fromIdx = j end
                        if n == clickName then toIdx   = j end
                    end
                    local fromZX  = wx + (fromIdx - 1) * tabW
                    local toZX    = wx + (toIdx - 1) * tabW
                    local lineY   = barY + barH - 2
                    local token = newAnimToken()
                    task.spawn(function()
                        local steps = 10
                        for k = 1, steps do
                            if not isAnimCurrent(token) then return end
                            local t = k / steps
                            local et = 1 - (1 - t) ^ 3
                            local zx = fromZX + (toZX - fromZX) * et
                            pcall(function()
                                under.From = Vector2.new(zx + 1, lineY)
                                under.To   = Vector2.new(zx + tabW - 1, lineY)
                            end)
                            if glow then
                                pcall(function() glow.Position = Vector2.new(zx, barY) end)
                            end
                            task.wait(0.018)
                        end
                        rebuild()
                    end)
                else
                    rebuild()
                end
            end,
        })
    end
end

