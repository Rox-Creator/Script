-- ============================================================

local function sliderRising(vk)
    local down = iskeypressed(vk)
    local was  = GUI.SliderKeyState[vk]
    GUI.SliderKeyState[vk] = down
    return down and not was
end

local function InputLoop()
    while GUI.Running do
        repeat
        -- Slider value-edit mode
        if GUI.EditingSlider then
            local valChanged = false
            for vk = 0x30, 0x39 do
                if sliderRising(vk) then
                    GUI.SliderBuffer = GUI.SliderBuffer .. string.char(vk)
                    valChanged = true
                end
            end
            for vk = 0x60, 0x69 do
                if sliderRising(vk) then
                    GUI.SliderBuffer = GUI.SliderBuffer .. string.char(vk - 0x60 + 0x30)
                    valChanged = true
                end
            end
            if sliderRising(0xBE) or sliderRising(0x6E) then
                if not GUI.SliderBuffer:find("%.", 1, true) then
                    GUI.SliderBuffer = GUI.SliderBuffer .. "."
                    valChanged = true
                end
            end
            if sliderRising(0x08) then
                GUI.SliderBuffer = string.sub(GUI.SliderBuffer, 1, -2)
                valChanged = true
            end
            if sliderRising(0x0D) then
                local num = tonumber(GUI.SliderBuffer)
                if num and GUI.EditingSlider then
                    num = math.max(GUI.EditingSlider.minV,
                                   math.min(GUI.EditingSlider.maxV, num))
                    GUI.EditingSlider.onChange(num)
                end
                GUI.EditingSlider = nil; GUI.SliderBuffer = ""; GUI.SliderKeyState = {}
                if GUI.Visible and not GUI.Minimized then CreateContent() end
            end
            if GUI.EditingSlider and sliderRising(0x1B) then
                GUI.EditingSlider = nil; GUI.SliderBuffer = ""; GUI.SliderKeyState = {}
                if GUI.Visible and not GUI.Minimized then CreateContent() end
            end
            if valChanged and GUI.EditingSlider and GUI.EditingSlider.valTxt then
                pcall(function()
                    GUI.EditingSlider.valTxt.Text = GUI.SliderBuffer .. "_"
                end)
            end
            if GUI.Visible then
                local mx, my = Mouse.X, Mouse.Y
                local mouseDown = ismouse1pressed()
                local justPressed = mouseDown and not GUI.WasMouseDown
                if justPressed then
                    for _, c in ipairs(GUI.Clickables) do
                        if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                            if c.hover and c.hover.el then pressEffect(c.hover.el) end
                            c.onClick()
                            break
                        end
                    end
                end
                GUI.WasMouseDown = mouseDown
            else
                GUI.WasMouseDown = false
            end
            break
        end

        -- Hitbox / AutoKill bind capture
        if ListeningForBind == "hitbox" or ListeningForBind == "autokill" then
            for vk = 0x08, 0xFE do
                if vk ~= VK_END and iskeypressed(vk) then
                    if ListeningForBind == "hitbox" then
                        HitboxKey = vk
                        GUI.WasHitboxKeyDown = true
                    else
                        AutoKillKey = vk
                        GUI.WasAutoKillKeyDown = true
                    end
                    ListeningForBind = nil
                    if GUI.Visible and not GUI.Minimized then CreateContent() end
                    task.wait(0.3)
                    break
                end
            end
        end

        -- Toggle / Debug key rebind capture
        if GUI.ListeningForKey then
            for vk = 0x08, 0xFE do
                if vk ~= VK_END and iskeypressed(vk) then
                    GUI.ToggleKey = vk
                    GUI.ListeningForKey = false
                    GUI.WasToggleDown = true
                    if GUI.HintText then
                        pcall(function()
                            GUI.HintText.Text = getKeyName(vk) .. " Toggle | End Unload"
                        end)
                    end
                    if GUI.Visible then CreateContent() end
                    task.wait(0.3)
                    break
                end
            end
        end
        -- Farm hotkeys (rising-edge)
        if not ListeningForBind and not GUI.ListeningForKey then
            local hbDown = iskeypressed(HitboxKey)
            if hbDown and not GUI.WasHitboxKeyDown then
                setHitboxOn(not Features.HitboxExpander)
            end
            GUI.WasHitboxKeyDown = hbDown

            local akDown = iskeypressed(AutoKillKey)
            if akDown and not GUI.WasAutoKillKeyDown then
                setAutoKillOn(not Features.AutoKill)
            end
            GUI.WasAutoKillKeyDown = akDown
        end

        -- End → unload (with rising-edge guard)
        local endDown = iskeypressed(VK_END)
        if GUI.EndKeyReady then
            if endDown and not GUI.WasEndDown then
                UnloadScript()
                return
            end
        else
            if not endDown then GUI.EndKeyReady = true end
        end
        GUI.WasEndDown = endDown

        -- Toggle GUI visibility
        if not GUI.ListeningForKey then
            local toggleDown = iskeypressed(GUI.ToggleKey)
            if toggleDown and not GUI.WasToggleDown then
                GUI.Visible = not GUI.Visible
                if not GUI.Visible then
                    for _, el in ipairs(GUI.Elements) do
                        pcall(function() el.Visible = false end)
                    end
                    for _, el in ipairs(GUI.NavElements) do
                        pcall(function() el.Visible = false end)
                    end
                    ClearContent()
                    clearMiniPanel()
                    clearTooltip()
                else
                    applyMinimizedState()
                end
            end
            GUI.WasToggleDown = toggleDown
        end

        if GUI.Visible then
            local mx, my = Mouse.X, Mouse.Y
            local mouseDown = ismouse1pressed()
            local justPressed = mouseDown and not GUI.WasMouseDown

            if GUI.ActiveSlider then
                if mouseDown then pcall(GUI.ActiveSlider) else GUI.ActiveSlider = nil end
            end

            local onHeader = IsInside(mx, my, Config.WinX, Config.WinY, Config.WinW, Config.HeaderH)

            for _, c in ipairs(GUI.Clickables) do
                local isOver = IsInside(mx, my, c.x, c.y, c.w, c.h)
                if c.hover and c.hover.el then
                    if isOver and not c.hover.hovered then
                        pcall(function() c.hover.el.Color = lighten(c.hover.base, 0.10) end)
                        if c.hover.glow then pcall(function() c.hover.glow.Visible = true end) end
                        c.hover.hovered = true
                    elseif (not isOver) and c.hover.hovered then
                        pcall(function() c.hover.el.Color = c.hover.base end)
                        if c.hover.glow then pcall(function() c.hover.glow.Visible = false end) end
                        c.hover.hovered = false
                    end
                end
                if c.tooltip then
                    if isOver and not c.tooltipShown then
                        showTooltip(c.tooltip, mx + 14, my + 14)
                        c.tooltipShown = true
                    elseif (not isOver) and c.tooltipShown then
                        clearTooltip()
                        c.tooltipShown = false
                    end
                end
            end

            if GUI.Dragging then
                if mouseDown then
                    local newX = mx - GUI.DragOffsetX
                    local newY = my - GUI.DragOffsetY
                    local ddx = newX - Config.WinX
                    local ddy = newY - Config.WinY
                    if ddx ~= 0 or ddy ~= 0 then MoveWindow(ddx, ddy) end
                else
                    GUI.Dragging = false
                    CreateContent()
                end
            end

            if justPressed then
                local handled = false

                for _, c in ipairs(GUI.NavClickables) do
                    if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                        if c.hover and c.hover.el then pressEffect(c.hover.el) end
                        c.onClick()
                        handled = true
                        break
                    end
                end

                if not handled then
                    for _, c in ipairs(GUI.Clickables) do
                        if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                            if c.hover and c.hover.el then pressEffect(c.hover.el) end
                            if c.sliderDrag then GUI.ActiveSlider = c.sliderDrag end
                            c.onClick()
                            handled = true
                            break
                        end
                    end
                end

                if not handled and onHeader then
                    GUI.Dragging = true
                    GUI.DragOffsetX = mx - Config.WinX
                    GUI.DragOffsetY = my - Config.WinY
                end
            end
            GUI.WasMouseDown = mouseDown
        else
            GUI.WasMouseDown = false
        end

        until true
        task.wait(0.016)
    end
end

