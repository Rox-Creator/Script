local function getViewportSize()
    local cam = Workspace and Workspace.CurrentCamera
    if cam then
        local ok, vp = pcall(function() return cam.ViewportSize end)
        if ok and vp and vp.X and vp.X > 0 then return vp.X, vp.Y end
    end
    return 1920, 1080
end

local MINI_W = 280
local MINI_ROW_H = 22
local MINI_HEADER_H = 28

local function clearMiniPanel()
    for _, el in ipairs(GUI.MiniElements) do
        pcall(function() el:Remove() end)
    end
    GUI.MiniElements = {}
    GUI.MiniLiveElements = {}
    GUI.MiniTitansVal = nil
    GUI.MiniSizeVal   = nil
    GUI.MiniKilledVal = nil
    GUI.MiniUptimeVal = nil
end

local function buildMiniPanel()
    clearMiniPanel()
    local rows = {}
    if Features.HitboxExpander then
        table.insert(rows, { label = "Titans",      key = "titans" })
        table.insert(rows, { label = "Hitbox Size", key = "size"   })
    end
    if Features.AutoKill then
        if not Features.HitboxExpander then
            table.insert(rows, { label = "Titans", key = "titans" })
        end
        table.insert(rows, { label = "Killed", key = "killed" })
        table.insert(rows, { label = "Uptime", key = "uptime" })
    end
    if #rows == 0 then return end

    local vpW, _ = getViewportSize()
    local noteH = 18
    local h = MINI_HEADER_H + #rows * MINI_ROW_H + noteH + 10
    local x = math.floor((vpW - MINI_W) / 2)
    local y = 20
    local z = 80

    local bg = Drawing.new("Square")
    bg.Position = Vector2.new(x, y); bg.Size = Vector2.new(MINI_W, h)
    bg.Color = Colors.HeaderInfoBg; bg.Filled = true; bg.Corner = 6
    bg.Transparency = 0.55
    bg.Visible = true; bg.ZIndex = z
    table.insert(GUI.MiniElements, bg)

    local border = Drawing.new("Square")
    border.Position = Vector2.new(x, y); border.Size = Vector2.new(MINI_W, h)
    border.Color = Colors.AccentRed; border.Filled = false
    border.Thickness = 1; border.Corner = 6
    border.Visible = true; border.ZIndex = z + 1
    table.insert(GUI.MiniElements, border)

    local title = Drawing.new("Text")
    title.Position = Vector2.new(x + 12, y + 8)
