-- Auto Kill drop pattern: TPs the player to (nape + DropHeight) every
-- cycle without zeroing AssemblyLinearVelocity, so downward speed
-- builds up and the player slams through the nape at increasing speed.
-- Floor check stops it from passing the nape (which would trigger
-- nape-grab); an anchor every N cycles zeroes velocity so it doesn't
-- grow unboundedly. Auto-engages its own (smaller) hitbox expansion.
local AutoKillHitboxSize    = 150
local AutoKillDropHeight    = 90    -- studs above nape we snap to each cycle
local AutoKillDropDwell     = 0.15  -- max seconds to fall before TP'ing back up
