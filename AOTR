local function MoveWindow(dx, dy)
    Config.WinX = Config.WinX + dx
    Config.WinY = Config.WinY + dy

    local function moveEl(el)
        pcall(function()
            if el.Position then el.Position = Vector2.new(el.Position.X + dx, el.Position.Y + dy) end
        end)
        pcall(function()
            if el.From then el.From = Vector2.new(el.From.X + dx, el.From.Y + dy) end
        end)
        pcall(function()
            if el.To then el.To = Vector2.new(el.To.X + dx, el.To.Y + dy) end
        end)
    end

    newAnimToken()

    for _, el in ipairs(GUI.Elements)        do moveEl(el) end
    for _, el in ipairs(GUI.NavElements)     do moveEl(el) end
    for _, el in ipairs(GUI.SubTabElements)  do moveEl(el) end
    for _, el in ipairs(GUI.ContentElements) do moveEl(el) end

    for _, c in ipairs(GUI.NavClickables) do c.x = c.x + dx; c.y = c.y + dy end
    for _, c in ipairs(GUI.Clickables)    do c.x = c.x + dx; c.y = c.y + dy end
end

