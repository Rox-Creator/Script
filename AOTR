-- ============================================================

local tooltipEls = {}

local function clearTooltip()
    for _, el in ipairs(tooltipEls) do
        pcall(function() el:Remove() end)
    end
    tooltipEls = {}
end

local function showTooltip(text, x, y)
    clearTooltip()
    if not text or text == "" then return end
    local lines = {}
    for line in (text .. "\n"):gmatch("([^\n]*)\n") do table.insert(lines, line) end
    while #lines > 0 and lines[#lines] == "" do table.remove(lines, #lines) end
    if #lines == 0 then return end

    local pad, lineH, fontSize, charW = 8, 14, 11, 6
    local maxChars = 0
    for _, line in ipairs(lines) do
        if #line > maxChars then maxChars = #line end
    end
    local boxW = maxChars * charW + pad * 2
    local boxH = #lines * lineH + pad

    local vpW, vpH = 1920, 1080
    local cam = Workspace and Workspace.CurrentCamera
    if cam then
        local ok, vp = pcall(function() return cam.ViewportSize end)
        if ok and vp and vp.X and vp.X > 0 then vpW, vpH = vp.X, vp.Y end
    end
    if x + boxW > vpW - 4 then x = vpW - boxW - 4 end
    if y + boxH > vpH - 4 then y = vpH - boxH - 4 end
    if x < 4 then x = 4 end
    if y < 4 then y = 4 end

    local bg = Drawing.new("Square")
    bg.Position = Vector2.new(x, y); bg.Size = Vector2.new(boxW, boxH)
    bg.Color = Colors.HeaderBg; bg.Filled = true; bg.Corner = 4
    bg.Visible = true; bg.ZIndex = 95
    table.insert(tooltipEls, bg)

    local border = Drawing.new("Square")
    border.Position = Vector2.new(x, y); border.Size = Vector2.new(boxW, boxH)
    border.Color = Colors.AccentRed; border.Filled = false; border.Thickness = 1
    border.Corner = 4; border.Visible = true; border.ZIndex = 96
    table.insert(tooltipEls, border)

    for i, line in ipairs(lines) do
        local txt = Drawing.new("Text")
        txt.Position = Vector2.new(x + pad, y + pad - 4 + (i - 1) * lineH)
        txt.Text = line; txt.Color = Colors.TextPrimary
        txt.Size = fontSize; txt.Font = Drawing.Fonts.System
        txt.Center = false; txt.Outline = false
        txt.Visible = true; txt.ZIndex = 97
        table.insert(tooltipEls, txt)
    end
end

