-- Uptime tracker for AutoKill (Bridger pattern).
local killUptime = { total = 0, start = nil }
local function uptimeSyncGeneric(u, active)
    if active then
        if not u.start then u.start = tick() end
    else
        if u.start then
            u.total = u.total + (tick() - u.start)
            u.start = nil
        end
    end
end
local function syncKillUptime() uptimeSyncGeneric(killUptime, Features.AutoKill) end
local function getUptimeSeconds(u)
    if u.start then return u.total + (tick() - u.start) end
    return u.total
end

